diff --git a/README.md b/README.md
index 2371ff6..5854ab7 100644
--- a/README.md
+++ b/README.md
@@ -1,6 +1,7 @@
 # Release Model Radar — iOS
 
-Native SwiftUI client for [Release Model Radar](https://release.brightening.ca).
+Native SwiftUI client for [Release Model Radar](https://release.brightening.ca)
+(Phase 3 of the roadmap).
 The web app remains the source of truth; this app only consumes its public,
 read-only JSON API. No keys, no auth, no mutation, no scraping.
 
@@ -53,4 +54,8 @@ See `docs/ios-mvp-plan.md` for the phase plan.
 ## Out of scope for this MVP (deliberately)
 
 App Store signing, widgets, push notifications, accounts/auth, favourites,
-and persistent offline cache — see Phases 2–3 in the plan.
+and persistent offline cache — see Phases 4–5 in the plan.
+
+This app is **Phase 3** of the Release Model Radar roadmap. App Store
+signing/distribution is not set up yet; the MVP baseline can be locked
+after review — signing is a release task, not an MVP task.
diff --git a/ReleaseModelRadar/API/APIClient.swift b/ReleaseModelRadar/API/APIClient.swift
index 351a76a..77fedab 100644
--- a/ReleaseModelRadar/API/APIClient.swift
+++ b/ReleaseModelRadar/API/APIClient.swift
@@ -52,8 +52,11 @@ actor APIClient {
                 }
                 throw APIError.http(http.statusCode)
             }
+            // Decode FIRST — only a response that fully decodes counts as
+            // "last successful" and earns a place in the fallback cache.
+            let value: T = try decodeEnvelope(data)
             memoryCache[path] = data
-            return try decodeEnvelope(data)
+            return value
         } catch let error as APIError {
             throw error
         } catch {
@@ -65,7 +68,13 @@ actor APIClient {
     }
 
     private func decodeEnvelope<T: Decodable>(_ data: Data) throws -> T {
-        guard let envelope = try? JSONDecoder().decode(Envelope<T>.self, from: data) else {
+        let envelope: Envelope<T>
+        do {
+            envelope = try JSONDecoder().decode(Envelope<T>.self, from: data)
+        } catch {
+            #if DEBUG
+            print("APIClient: envelope decode failed —", error)
+            #endif
             throw APIError.decoding
         }
         guard envelope.ok, let payload = envelope.data else {
diff --git a/ReleaseModelRadar/API/APIModels.swift b/ReleaseModelRadar/API/APIModels.swift
index c6ae817..9e87d1a 100644
--- a/ReleaseModelRadar/API/APIModels.swift
+++ b/ReleaseModelRadar/API/APIModels.swift
@@ -5,9 +5,11 @@ import Foundation
    lib/news/fetchNews.ts, and lib/api/types.ts. */
 
 /// Shared response envelope: { ok, generatedAt, count, data } / { ok:false, error }.
+/// Everything except `ok` is tolerant of omission so a slightly off-spec
+/// failure envelope still decodes instead of masking the real error.
 struct Envelope<T: Decodable>: Decodable {
     let ok: Bool
-    let generatedAt: String
+    let generatedAt: String?
     let count: Int?
     let data: T?
     let error: String?
@@ -42,7 +44,8 @@ struct RadarModel: Decodable, Identifiable, Hashable {
     let strengths: [String]
     let watchouts: [String]
     let useFor: String
-    let forDario: String?
+    // Note: the API also serves a personalized `forDario` field; this app
+    // deliberately does not decode or render it — public/product-safe only.
     let sentiment: Sentiment
     let link: String
     let openWeight: Bool?
