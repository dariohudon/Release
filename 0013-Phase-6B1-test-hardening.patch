@@ -91,6 +91,27 @@ final class LabFavoritesStoreTests: XCTestCase {
         XCTAssertTrue(reloaded.newInfoLabIDs.isEmpty)
     }
 
+    /// One unexpectedly empty (but successful) labs payload must not wipe
+    /// favourites or snapshots; pruning resumes on the next non-empty load.
+    func test_emptyLabsPayloadDoesNotWipeFavourites() {
+        let store = LabFavoritesStore(defaults: defaults)
+        store.toggle("anthropic")
+        store.recordLabsSnapshot([lab("anthropic", count: 5)])
+
+        store.recordLabsSnapshot([])
+        XCTAssertTrue(store.isFavorite("anthropic"), "empty payload must not prune favourites")
+        XCTAssertTrue(store.newInfoLabIDs.isEmpty)
+
+        // Snapshot survived the empty payload: a changed count still flags.
+        store.recordLabsSnapshot([lab("anthropic", count: 6)])
+        XCTAssertEqual(store.newInfoLabIDs, ["anthropic"])
+
+        // Pruning still works against a NON-empty payload missing the lab.
+        store.recordLabsSnapshot([lab("google", count: 4)])
+        XCTAssertFalse(store.isFavorite("anthropic"))
+        XCTAssertTrue(store.newInfoLabIDs.isEmpty)
+    }
+
     func test_unfavouritingClearsItsIndicator() {
         let store = LabFavoritesStore(defaults: defaults)
         store.toggle("meta")
diff --git a/ReleaseModelRadarTests/LocalAPIResponseCacheTests.swift b/ReleaseModelRadarTests/LocalAPIResponseCacheTests.swift
index 3ca807a..56a89ca 100644
--- a/ReleaseModelRadarTests/LocalAPIResponseCacheTests.swift
+++ b/ReleaseModelRadarTests/LocalAPIResponseCacheTests.swift
@@ -3,8 +3,32 @@ import XCTest
 
 final class LocalAPIResponseCacheTests: XCTestCase {
 
+    private var createdDirectories: [String] = []
+
+    override func tearDown() {
+        // Remove only the temporary "Test-…" directories this test created —
+        // never the app's real APIResponseCache directory.
+        for name in createdDirectories {
+            try? FileManager.default.removeItem(at: Self.cachesURL(for: name))
+        }
+        createdDirectories = []
+        super.tearDown()
+    }
+
+    static func cachesURL(for directoryName: String) -> URL {
+        let base = FileManager.default.urls(for: .cachesDirectory, in: .userDomainMask).first
+            ?? FileManager.default.temporaryDirectory
+        return base.appendingPathComponent(directoryName, isDirectory: true)
+    }
+
+    private func makeDirectoryName() -> String {
+        let name = "Test-\(UUID().uuidString)"
+        createdDirectories.append(name)
+        return name
+    }
+
     private func makeCache() -> LocalAPIResponseCache {
-        LocalAPIResponseCache(directoryName: "Test-\(UUID().uuidString)")
+        LocalAPIResponseCache(directoryName: makeDirectoryName())
     }
 
     func test_saveAndLoadRoundtrip() async {
@@ -36,7 +60,7 @@ final class LocalAPIResponseCacheTests: XCTestCase {
 
     /// Disk entries must survive recreating the cache (≈ app relaunch).
     func test_persistsAcrossInstances() async {
-        let directory = "Test-\(UUID().uuidString)"
+        let directory = makeDirectoryName()
         let first = LocalAPIResponseCache(directoryName: directory)
         await first.save(Data("persisted".utf8), for: "/api/labs")
 
