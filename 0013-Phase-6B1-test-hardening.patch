@@ -57,6 +57,12 @@ final class LabFavoritesStore: ObservableObject {
     /// renamed/removed lab can never wedge the favourites list or leave a
     /// permanent ghost indicator.
     func recordLabsSnapshot(_ labs: [Lab]) {
+        // Guard: one unexpectedly empty (but successful) labs payload must
+        // not wipe favourites or snapshots — skip entirely and wait for the
+        // next non-empty refresh. Pruning only ever runs against a payload
+        // that contains at least one lab.
+        guard !labs.isEmpty else { return }
+
         var snapshot = stringDictionary(Key.modelCounts)
         var flagged = newInfoLabIDs
         for lab in labs {
diff --git a/ReleaseModelRadarTests/APIClientCachePolicyTests.swift b/ReleaseModelRadarTests/APIClientCachePolicyTests.swift
index 98112aa..9c9ff9b 100644
--- a/ReleaseModelRadarTests/APIClientCachePolicyTests.swift
+++ b/ReleaseModelRadarTests/APIClientCachePolicyTests.swift
@@ -43,6 +43,11 @@ final class APIClientCachePolicyTests: XCTestCase {
 
     override func tearDown() {
         MockURLProtocol.handler = nil
+        // Remove this test's temporary cache directory (never the app's
+        // real APIResponseCache directory).
+        try? FileManager.default.removeItem(
+            at: LocalAPIResponseCacheTests.cachesURL(for: cacheDirectory)
+        )
         super.tearDown()
     }
 
@@ -97,10 +102,36 @@ final class APIClientCachePolicyTests: XCTestCase {
         XCTAssertEqual(outcome.value, Payload(value: "A"))
         guard case .cached = outcome.source else { return XCTFail("expected .cached") }
 
-        // Still good after another failure round (cache was not poisoned).
+        // Still good after another failure round (memory was not poisoned).
         failNetwork()
         let again = try await client.fetchWithCache("/api/test", as: Payload.self)
         XCTAssertEqual(again.value, Payload(value: "A"))
+
+        // Strongest proof: a brand-new client (empty memory, same disk
+        // directory) with no network must still serve the good value —
+        // i.e. the ON-DISK cache was never overwritten by the garbage.
+        let recreated = makeClient()
+        failNetwork()
+        let fromDisk = try await recreated.fetchWithCache("/api/test", as: Payload.self)
+        XCTAssertEqual(fromDisk.value, Payload(value: "A"))
+        guard case .cached = fromDisk.source else { return XCTFail("expected .cached from disk") }
+    }
+
+    /// ok:false with HTTP 200 (not just 404) is still an authoritative
+    /// server answer — it must throw and must not be masked by stale cache.
+    func test_okFalseWithHTTP200IsNotMaskedByCache() async throws {
+        let client = makeClient()
+        respond(status: 200, body: goodA)
+        _ = try await client.fetchWithCache("/api/test", as: Payload.self)
+
+        respond(status: 200, body: #"{"ok":false,"generatedAt":"2026-06-12T00:00:00.000Z","error":"temporarily unavailable","data":null}"#)
+        do {
+            _ = try await client.fetchWithCache("/api/test", as: Payload.self)
+            XCTFail("expected APIError.api to be thrown")
+        } catch let error as APIError {
+            guard case .api(let message) = error else { return XCTFail("expected .api, got \(error)") }
+            XCTAssertEqual(message, "temporarily unavailable")
+        }
     }
 
     func test_authoritativeOkFalseIsNotMaskedByCache() async throws {
